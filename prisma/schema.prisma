// This is your Prisma schema file
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ORGANIZATION
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  PENDING
  INCOMPLETE_PROFILE
  BANNED
}

enum PostType {
  DONATION
  REQUEST
}

enum PostStatus {
  AVAILABLE
  PENDING_HANDOVER
  COMPLETED
  EXPIRED
  SUSPENDED
}

enum DeliveryType {
  RECEIVER_PICKUP
  DONOR_DELIVERY
  COURIER
  NEGOTIABLE
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum PostCategory {
  COOKED_FOOD
  DRY_FOOD
  CLOTHING
  FURNITURE
  ELECTRONICS
  MEDICAL_SUPPLIES
  OTHERS
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  passwordHash        String?
  phone               String?       @unique
  role                UserRole      @default(USER)
  status              AccountStatus @default(ACTIVE)
  profilePictureUrl   String?
  needsPasswordChange Boolean       @default(false)
  authProvider        String?       @default("local")
  isVerified          Boolean       @default(false)
  otp                 String?
  otpExpiry           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // One-to-One Profile Delegation
  userProfile         UserProfile?
  organizationProfile OrganizationProfile?
  adminProfile        AdminProfile?

  // Core Relations
  posts               Post[]
  transactionRequests TransactionRequest[]
  reviewsGiven        Review[]             @relation("Reviewer")
  reviewsReceived     Review[]             @relation("Reviewee")
  likes               Like[]
  comments            Comment[]
  sessions            Session[]
  notifications       Notification[]

  @@map("users")
}

model UserProfile {
  id          String @id @default(uuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  latitude    Float?
  longitude   Float?
  impactScore Float  @default(0)

  @@map("user_profiles")
}

model OrganizationProfile {
  id                 String  @id @default(uuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgName            String
  establishedYear    Int?
  registrationNumber String?
  latitude           Float
  longitude          Float
  impactScore        Float   @default(0)

  @@map("organization_profiles")
}

model AdminProfile {
  id         String  @id @default(uuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  department String?

  @@map("admin_profiles")
}

model Post {
  id                 String       @id @default(uuid())
  authorId           String
  author             User         @relation(fields: [authorId], references: [id])
  type               PostType
  category           PostCategory
  title              String
  description        String
  imageUrls          String[]
  quantity           Int
  estimatedShelfLife DateTime?
  metadata           Json?
  latitude           Float
  longitude          Float
  status             PostStatus   @default(AVAILABLE)
  deliveryType       DeliveryType @default(NEGOTIABLE)
  likesCount         Int          @default(0)
  commentsCount      Int          @default(0)
  createdAt          DateTime     @default(now())

  transactionRequests TransactionRequest[]
  likes               Like[]
  comments            Comment[]

  @@map("posts")
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("likes")
}

model Comment {
  id        String    @id @default(uuid())
  content   String
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentToComment")
  createdAt DateTime  @default(now())

  @@map("comments")
}

model TransactionRequest {
  id        String            @id @default(uuid())
  postId    String
  post      Post              @relation(fields: [postId], references: [id])
  actorId   String
  actor     User              @relation(fields: [actorId], references: [id])
  quantity  String
  status    TransactionStatus @default(PENDING)
  message   String?
  createdAt DateTime          @default(now())

  reviews Review[]

  @@map("transaction_requests")
}

model Review {
  id            String             @id @default(uuid())
  reviewerId    String
  reviewer      User               @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId    String
  reviewee      User               @relation("Reviewee", fields: [revieweeId], references: [id])
  transactionId String
  transaction   TransactionRequest @relation(fields: [transactionId], references: [id])
  rating        Int
  comment       String?
  createdAt     DateTime           @default(now())

  @@map("reviews")
}

model AiLog {
  id         String   @id @default(uuid())
  actionType String
  prompt     String
  response   String
  createdAt  DateTime @default(now())

  @@map("ai_logs")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("sessions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  type      String // E.g., 'INFO', 'REQUEST', 'ACCEPT'
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}
